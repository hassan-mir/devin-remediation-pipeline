# Copy to .env and fill in. Comments are on their own lines so docker compose env_file
# parses every value cleanly. Secrets/connection live here; tunables are also editable
# from the dashboard Configuration panel at runtime.

# --- Devin API (v3, organization-scoped) ---
DEVIN_API_KEY=cog_xxxxxxxxxxxxxxxxxxxxx
# Devin organization id (from Devin Settings)
DEVIN_ORG_ID=hassan-mir-devin-demo
DEVIN_BASE_URL=https://api.devin.ai/v3
# normal | fast | lite | ultra
DEVIN_MODE=normal
MAX_ACU_PER_SESSION=5
MAX_ACU_TRIAGE=2

# --- Calibrated-Autonomy policy (HITL score -> tier thresholds) ---
HITL_AUTO_MERGE_BELOW=20
HITL_AUTO_PR_BELOW=70
HITL_APPROVE_FIRST_BELOW=90
ENABLE_AUTO_MERGE=false
AUTONOMOUS_MODE=false

# --- GitHub ---
# Optional. Devin's own GitHub App access handles branches/PRs/reviews.
# A token is only needed for issue comments, creating issues from scans, and auto-merge.
GITHUB_TOKEN=
GITHUB_REPO=hassan-mir/superset
REMEDIATE_LABEL=devin-remediate
TRIAGE_LABEL=devin-triage
FIX_NOW_LABEL=devin-fix
GITHUB_WEBHOOK_SECRET=

# --- GitHub issue discovery (pull issues from a source repo) ---
ISSUE_SOURCE_REPO=hassan-mir/superset
# Optional comma-separated label filter, e.g. bug
ISSUE_SOURCE_LABELS=
# Optional comma-separated specific issue numbers, e.g. 1,2,3,4
ISSUE_SOURCE_NUMBERS=
ISSUE_PULL_LIMIT=8

# --- Orchestrator ---
MAX_CONCURRENT_SESSIONS=8
POLL_INTERVAL_SECONDS=10

# --- Estimation assumption (drives "hours saved") ---
ENGINEER_HOURS_PER_FIX=3

# --- Storage ---
DB_PATH=data/pipeline.db
RUNTIME_CONFIG_PATH=data/runtime_config.json
